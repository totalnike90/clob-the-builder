{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git worktree list:*)",
      "Bash(git fetch:*)",
      "Bash(bash .claude/ritual/scripts/ritual-config.sh:*)",
      "Bash(bash .claude/ritual/scripts/propagate-env-to-worktree.sh:*)",
      "Bash(python3 .claude/ritual/scripts/slice-buildlog.py:*)",
      "Bash(python3 .claude/ritual/scripts/regen-followups.py:*)",
      "Bash(python3 .claude/ritual/scripts/doctor.py:*)",
      "Bash(python3 .claude/ritual/scripts/sync-masterplan-status.py:*)",
      "Bash(python3 .claude/ritual/scripts/backfill-buildlog-anchors.py:*)",
      "Bash(jq:*)",
      "Bash(yq:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/ritual/hooks/guard-main.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "bash .claude/ritual/hooks/remind-non-negotiables.sh" }
        ]
      }
    ]
  }
}
