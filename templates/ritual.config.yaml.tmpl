# ritual.config.yaml — clob-the-builder project config
# Generated by install.sh; populated further by /plan-init.
# Full schema: https://github.com/totalnike90/clob-the-builder#config-schema

ritual_version: {{RITUAL_VERSION}}

paths:
  prd: {{PRD_PATH}}                # set at install or by /plan-init <PATH>
  design_system: {{DESIGN_SYSTEM_PATH}}
  prototypes: {{PROTOTYPES_PATH}}
  masterplan: MASTERPLAN.md
  buildlog: BUILDLOG.md
  followups: FOLLOWUPS.md
  taskstate: .taskstate/
  worktrees: .worktrees/

git:
  main_branch: main
  branch_pattern: "task/{id_lc}-{slug}"
  worktree_pattern: ".worktrees/{id_lc}/"

commit:
  trailer_keys: [Task]            # add e.g. PRD-refs, Slice in your project as needed
  squash_only: true

# Prefixes are populated by /plan-init from your PRD.
# Until then, all task-picking commands stop with "run /plan-init first".
prefixes: {}

# Gate commands — adapt to your stack via the chosen preset.
gates:
{{GATES_BLOCK}}

retry_budgets:
  check: 3
  review: 2
  auto_fix_max_lines: 20

walk:
  dev_server_cmd: {{DEV_SERVER_CMD}}
  default_port: 3000

reviewer:
  rules_file: .claude/ritual/reviewer.project.md
  # Non-negotiables populated by /plan-init from your PRD.
  non_negotiables: []

hooks:
  pre_tool_use: [guard-main]
  post_tool_use: [remind-non-negotiables]
  # post_worktree_create: ["bash scripts/your-env-setup.sh"]   # optional, project-supplied
